# ~/.env_init - Inicialização de ferramentas CLI

# Starship Prompt
eval "$(starship init bash)"

# FZF (Key bindings e fuzzy completion)
eval "$(fzf --bash)"

# Zoxide (Substituto inteligente do cd)
eval "$(zoxide init bash)"

# Mise (Gerenciador de runtimes/ferramentas)
eval "$(/home/ventura/.local/bin/mise activate bash)"

